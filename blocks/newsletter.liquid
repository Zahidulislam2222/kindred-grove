{%- comment -%}
  Newsletter block — inline signup form for midpage placement. Uses the
  same Shopify contact_form + 'newsletter' tag convention as the footer
  form. Full Klaviyo API wiring deferred to Day 12 per PROJECT_PLAN §11.
  If a Klaviyo list ID is set, the form posts to Klaviyo's endpoint.
{%- endcomment -%}

<section class="kg-newsletter section" {{ block.shopify_attributes }}>
  <div class="container stack">
    <header class="stack-sm text-center">
      {%- if block.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ block.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="h2">{{ block.settings.heading | default: 'Join the table' | escape }}</h2>
      {%- if block.settings.body != blank -%}
        <p class="text-lg text-muted">{{ block.settings.body | escape }}</p>
      {%- endif -%}
    </header>

    {%- form 'contact', class: 'kg-newsletter__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="kg-newsletter__row">
        <label for="NewsletterBlockEmail" class="visually-hidden">{{ 'footer.newsletter.email_label' | t }}</label>
        <input
          id="NewsletterBlockEmail"
          type="email"
          name="contact[email]"
          class="input"
          placeholder="{{ 'footer.newsletter.email_placeholder' | t }}"
          autocomplete="email"
          required
        >
        {% render 'button', label: 'Subscribe', variant: 'primary', type: 'submit' %}
      </div>
      {%- if form.posted_successfully? -%}
        <p class="kg-newsletter__success" role="status">{{ 'footer.newsletter.success' | t }}</p>
      {%- elsif form.errors -%}
        <p class="kg-newsletter__error" role="alert">{{ form.errors.translated_fields.email }} {{ form.errors.messages.email }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Recipes + early access" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join the table" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Seasonal recipes, harvest notes, and first access to new releases. No spam — ever." },
    { "type": "header", "content": "Klaviyo" },
    { "type": "text", "id": "klaviyo_list_id", "label": "Klaviyo list ID", "info": "Full Klaviyo API posting lands Day 12; form currently uses Shopify's built-in contact form with a 'newsletter' tag." }
  ],
  "presets": [
    { "name": "Newsletter", "category": "Marketing" }
  ]
}
{% endschema %}
