{%- comment -%}
  Farm story — reads from product.metafields.custom.farm (a Farm metaobject)
  when the block is rendered on a PDP and the metafield is populated.
  Otherwise uses the merchant-editable block settings. Same schema + same
  layout; the data source is switched transparently.

  Per ADR-003 + docs/metaobjects/SCHEMAS.md.
{%- endcomment -%}

{%- liquid
  assign layout = block.settings.layout | default: 'image-left'

  assign use_metaobject = false
  assign farm = null
  if template contains 'product' and product.metafields.custom.farm.value != blank
    assign use_metaobject = true
    assign farm = product.metafields.custom.farm.value
  endif

  if use_metaobject
    assign eyebrow_text = block.settings.eyebrow | default: 'farm_story.eyebrow' | t
    assign headline_text = farm.name | default: 'The grove has a name.'
    assign body_text = farm.story
    assign image_source = farm.photo
    assign meta_1_label = 'Region'
    if farm.region.value != blank
      assign meta_1_value = farm.region.value.name
    else
      assign meta_1_value = farm.country
    endif
    assign meta_2_label = 'Farmer'
    if farm.farmer.value != blank
      assign meta_2_value = farm.farmer.value.name
    else
      assign meta_2_value = ''
    endif
    assign meta_3_label = 'Harvest'
    assign meta_3_value = farm.harvest_season
  else
    assign eyebrow_text = block.settings.eyebrow | default: 'farm_story.eyebrow' | t
    assign headline_text = block.settings.headline | default: 'The grove has a name.'
    assign body_text = block.settings.body
    assign image_source = block.settings.image
    assign meta_1_label = block.settings.meta_1_label
    assign meta_1_value = block.settings.meta_1_value
    assign meta_2_label = block.settings.meta_2_label
    assign meta_2_value = block.settings.meta_2_value
    assign meta_3_label = block.settings.meta_3_label
    assign meta_3_value = block.settings.meta_3_value
  endif

  assign link_text = block.settings.link_text | default: 'farm_story.cta' | t
-%}

<section class="kg-farm-story kg-farm-story--{{ layout }} section" {{ block.shopify_attributes }}>
  <div class="container">
    <div class="kg-farm-story__grid">
      <div class="kg-farm-story__media">
        {%- if image_source != blank -%}
          {% render 'image',
             image: image_source,
             sizes: '(min-width: 768px) 50vw, 100vw',
             class: 'kg-farm-story__image'
          %}
        {%- endif -%}
      </div>
      <div class="kg-farm-story__content stack">
        <p class="eyebrow">{{ eyebrow_text | escape }}</p>
        <h2 class="h2 kg-farm-story__headline">{{ headline_text | escape }}</h2>
        {%- if body_text != blank -%}
          <div class="text-lg kg-farm-story__body rte">{{ body_text }}</div>
        {%- endif -%}

        {%- if meta_1_label != blank -%}
          <dl class="kg-farm-story__meta cluster">
            {%- if meta_1_value != blank -%}
              <div class="kg-farm-story__meta-item">
                <dt>{{ meta_1_label | escape }}</dt>
                <dd>{{ meta_1_value | escape }}</dd>
              </div>
            {%- endif -%}
            {%- if meta_2_value != blank -%}
              <div class="kg-farm-story__meta-item">
                <dt>{{ meta_2_label | escape }}</dt>
                <dd>{{ meta_2_value | escape }}</dd>
              </div>
            {%- endif -%}
            {%- if meta_3_value != blank -%}
              <div class="kg-farm-story__meta-item">
                <dt>{{ meta_3_label | escape }}</dt>
                <dd>{{ meta_3_value | escape }}</dd>
              </div>
            {%- endif -%}
          </dl>
        {%- endif -%}

        {%- if block.settings.link_url != blank -%}
          {% render 'button',
             label: link_text,
             href: block.settings.link_url,
             variant: 'secondary'
          %}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Farm story",
  "settings": [
    { "type": "header", "content": "Data source" },
    { "type": "paragraph", "content": "On a product page, this block auto-reads the product's linked Farm metaobject (product.metafields.custom.farm) when present. Set the fields below for non-PDP placements or as a fallback." },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "layout", "label": "Image position", "options": [
      { "value": "image-left",  "label": "Image left / text right" },
      { "value": "image-right", "label": "Image right / text left" }
    ], "default": "image-left" },
    { "type": "header", "content": "Media (fallback)" },
    { "type": "image_picker", "id": "image", "label": "Farm photograph" },
    { "type": "header", "content": "Text (fallback)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "The grove has a name." },
    { "type": "textarea", "id": "body", "label": "Story", "default": "Our olive oil comes from a single family grove outside Nablus. The Abu Hamza family has tended these trees for five generations. Every bottle is traceable to their October harvest." },
    { "type": "header", "content": "Farm meta (fallback)" },
    { "type": "text", "id": "meta_1_label", "label": "Meta 1 label", "default": "Region" },
    { "type": "text", "id": "meta_1_value", "label": "Meta 1 value", "default": "Nablus, Palestine" },
    { "type": "text", "id": "meta_2_label", "label": "Meta 2 label", "default": "Farmer" },
    { "type": "text", "id": "meta_2_value", "label": "Meta 2 value", "default": "Abu Hamza family" },
    { "type": "text", "id": "meta_3_label", "label": "Meta 3 label", "default": "Harvest" },
    { "type": "text", "id": "meta_3_value", "label": "Meta 3 value", "default": "October, cold-pressed within 4h" },
    { "type": "header", "content": "Link" },
    { "type": "text", "id": "link_text", "label": "Link text", "default": "Read the full story" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "presets": [
    { "name": "Farm story", "category": "Content" }
  ]
}
{% endschema %}
