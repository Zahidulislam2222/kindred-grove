{%- comment -%}
  Recently viewed — renders an empty shell + `<kg-recently-viewed>` custom
  element. The element reads the recently-viewed handles from localStorage,
  fetches each product's JSON, and fills in product cards. Hides entirely
  when no history exists. Writes the current product's handle to localStorage
  on PDP load so the history builds naturally.
{%- endcomment -%}

<kg-recently-viewed
  class="kg-recently-viewed section"
  data-current-handle="{{ product.handle }}"
  data-current-title="{{ product.title | escape }}"
  data-heading="{{ block.settings.heading | default: 'Recently viewed' | escape }}"
  data-max="{{ block.settings.max | default: 4 }}"
  {{ block.shopify_attributes }}
  hidden
>
  <div class="container stack">
    <h2 class="h3">{{ block.settings.heading | default: 'Recently viewed' | escape }}</h2>
    <ul class="kg-recently-viewed__grid grid grid-4" data-kg-rv-grid></ul>
  </div>
</kg-recently-viewed>

<script src="{{ 'recently-viewed.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Recently viewed",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Recently viewed" },
    { "type": "range", "id": "max", "label": "Max products to show", "min": 2, "max": 6, "step": 1, "default": 4 }
  ]
}
{% endschema %}
