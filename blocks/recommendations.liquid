{%- comment -%}
  Product recommendations — renders an empty shell + `<kg-recommendations>`
  Web Component. On scroll-into-view (IntersectionObserver) the element
  fetches /recommendations/products.json?product_id=X&limit=N and fills
  in product cards. Lazy-loading avoids paying the cost for visitors who
  never scroll that far.
{%- endcomment -%}

{%- liquid
  assign max = block.settings.max | default: 4
  assign intent = block.settings.intent | default: 'related'
-%}

<kg-recommendations
  class="kg-recs section"
  data-product-id="{{ product.id }}"
  data-max="{{ max }}"
  data-intent="{{ intent }}"
  {{ block.shopify_attributes }}
>
  <div class="container stack">
    <header class="stack-sm">
      {%- if block.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ block.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="h3">{{ block.settings.heading | default: 'You might also like' | escape }}</h2>
    </header>
    <ul class="kg-recs__grid grid grid-4" data-kg-recs-grid>
      {%- comment -%} Placeholders keep CLS stable until real cards arrive. {%- endcomment -%}
      {%- for i in (1..max) -%}
        <li class="kg-recs__placeholder" aria-hidden="true"></li>
      {%- endfor -%}
    </ul>
  </div>
</kg-recommendations>

<script src="{{ 'recommendations.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Recommendations",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "You might also like" },
    { "type": "select", "id": "intent", "label": "Recommendation intent", "options": [
      { "value": "related", "label": "Related (Shopify default)" },
      { "value": "complementary", "label": "Complementary (frequently bought with)" }
    ], "default": "related" },
    { "type": "range", "id": "max", "label": "Max products to show", "min": 2, "max": 8, "step": 1, "default": 4 }
  ]
}
{% endschema %}
