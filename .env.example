# Kindred Grove — Environment Variables Template
#
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.
#
# For CI, equivalent values live in GitHub Actions Secrets (encrypted);
# see `docs/CI-SECRETS.md` (local) for provisioning instructions.

# =========================================
# Shopify — dev / staging / production themes
# =========================================
# <shop>.myshopify.com domain of the dev store
SHOPIFY_STORE_URL=
# Numeric theme IDs (from `shopify theme list` or admin UI)
SHOPIFY_THEME_ID_DEV=
SHOPIFY_THEME_ID_STAGING=
SHOPIFY_THEME_ID_PRODUCTION=

# Theme Access app password (shptka_...) — CLI auth for non-interactive pushes
SHOPIFY_CLI_THEME_TOKEN=

# Admin API access token (shpat_...) from a custom app at
# admin/settings/apps/development. Used by scripts/seed-dev-store.mjs.
# Scopes required: read_themes, write_themes, read_products.
ADMIN_API_TOKEN=

# Same custom-app credentials, used by the Shopify Lighthouse CI action
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Storefront password — only needed when the dev store is locked.
# Dev-plan stores force password protection on by default.
SHOPIFY_STORE_PASSWORD=

# Storefront API tokens (Phase 2 — headless candidate, not used yet)
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_STOREFRONT_API_TOKEN=

# =========================================
# Analytics
# =========================================
# GA4 Measurement ID (e.g. G-XXXXXXXXXX) — public, ships in page HTML
GA4_MEASUREMENT_ID=
GA4_STREAM_ID=

# Meta Pixel — SKIPPED in Phase 1 (see ROADMAP)
# META_PIXEL_ID=

# =========================================
# Observability — Sentry
# =========================================
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# =========================================
# Email / Marketing — Klaviyo (Day 12)
# =========================================
KLAVIYO_PUBLIC_API_KEY=
KLAVIYO_LIST_ID=

# =========================================
# Reviews — Judge.me (Day 12)
# =========================================
JUDGEME_SHOP_TOKEN=
JUDGEME_PLATFORM=

# =========================================
# Visual Regression — Percy
# =========================================
# Project token (web_...) from percy.io → project → Settings → General
PERCY_TOKEN=

# =========================================
# CI / Deployment
# =========================================
# Optional — enables Lighthouse CI PR comments.
# Install from https://github.com/apps/lighthouse-ci
LHCI_GITHUB_APP_TOKEN=

# Cloudflare — Phase 1.5 case-study site (Cloudflare Pages)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Not needed — the `gh` CLI handles GitHub auth via the OS keychain.
GITHUB_TOKEN=
