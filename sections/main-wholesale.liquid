{%- comment -%}
  Wholesale page host section. Accepts @theme + @app blocks so the merchant
  can compose hero → intro copy → wholesale form → FAQ → trust strip.
  Ships with a default preset (hero + text + wholesale-form + values-strip).
{%- endcomment -%}

<section class="kg-wholesale section" {{ section.shopify_attributes }}>
  <div class="container stack">
    {% content_for 'blocks' %}
  </div>
</section>

{% schema %}
{
  "name": "Wholesale main",
  "settings": [],
  "blocks": [
    { "type": "@theme" },
    { "type": "@app" }
  ],
  "default": {
    "blocks": [
      {
        "type": "hero",
        "settings": {
          "eyebrow": "Wholesale",
          "headline": "Stock the grove.",
          "body": "For restaurants, specialty grocers, and subscription boxes ready to carry single-origin Mediterranean staples.",
          "height": "small",
          "overlay_opacity": 45
        }
      },
      {
        "type": "text",
        "settings": {
          "element": "p",
          "text_size": "lg",
          "text_align": "center",
          "content": "<p>We'll follow up within two business days. Minimum first order is six cases; bulk-pricing tiers scale from there. If you're producing a recipe feature or retailer launch, tell us — we can tailor case mixes and include farmer profiles for your sales deck.</p>"
        }
      },
      { "type": "wholesale-form" }
    ]
  },
  "presets": [
    {
      "name": "Wholesale page",
      "blocks": [
        { "type": "hero" },
        { "type": "text" },
        { "type": "wholesale-form" }
      ]
    }
  ]
}
{% endschema %}
