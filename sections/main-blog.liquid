{%- comment -%}
  Blog listing — grid of articles with pagination. Host for @theme + @app
  blocks so the merchant can top the page with a hero/intro + trail with
  a newsletter/CTA. Default preset includes a hero + the article grid.
{%- endcomment -%}

<section class="kg-blog section" {{ section.shopify_attributes }}>
  <div class="container stack">
    <header class="kg-blog__header stack-sm">
      <p class="eyebrow">{{ blog.title | escape }}</p>
      <h1 class="h1">{{ 'blog.heading' | t | default: blog.title }}</h1>
    </header>

    {% content_for 'blocks' %}

    {%- paginate blog.articles by 12 -%}
      {%- if blog.articles.size > 0 -%}
        <ul class="kg-blog__grid grid grid-3 list-none">
          {%- for article in blog.articles -%}
            <li class="kg-blog__item">
              <a href="{{ article.url }}" class="kg-blog__link">
                {%- if article.image -%}
                  <div class="kg-blog__media">
                    {% render 'image',
                       image: article.image,
                       alt: article.title,
                       sizes: '(min-width: 768px) 33vw, 100vw',
                       widths: '400,600,800,1200'
                    %}
                  </div>
                {%- endif -%}
                <div class="kg-blog__body stack-sm">
                  {%- if article.tags.size > 0 -%}
                    <p class="eyebrow">{{ article.tags.first | escape }}</p>
                  {%- endif -%}
                  <h2 class="h3 kg-blog__title">{{ article.title | escape }}</h2>
                  {%- if article.excerpt_or_content != blank -%}
                    <p class="kg-blog__excerpt text-muted">{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p>
                  {%- endif -%}
                  <p class="text-sm text-muted">
                    <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%B %-d, %Y' }}</time>
                    {%- if article.author -%} · {{ article.author | escape }}{%- endif -%}
                  </p>
                </div>
              </a>
            </li>
          {%- endfor -%}
        </ul>

        {%- if paginate.pages > 1 -%}
          {%- assign pagination_next = 'blog.next' | t -%}
          {%- assign pagination_prev = 'blog.prev' | t -%}
          <nav class="kg-blog__pagination" aria-label="{{ 'blog.pagination' | t }}">
            {{ paginate | default_pagination: next: pagination_next, previous: pagination_prev }}
          </nav>
        {%- endif -%}
      {%- else -%}
        <p class="kg-blog__empty">{{ 'blog.empty' | t }}</p>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog main",
  "settings": [],
  "blocks": [
    { "type": "@theme" },
    { "type": "@app" }
  ],
  "presets": [
    { "name": "Blog" }
  ]
}
{% endschema %}
