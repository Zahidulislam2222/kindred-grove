{%- comment -%}
  Static main section for templates/index.json. Hosts homepage Theme Blocks.
  No wrapper container — each block controls its own max-width so full-bleed
  (hero, instagram strip) and contained (values, featured, farm story, reviews,
  newsletter) blocks can coexist cleanly.
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
  {%- content_for 'blocks' -%}
{%- else -%}
  <section class="section container text-center">
    <p class="text-muted">Add blocks to this homepage in the theme editor.</p>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Homepage",
  "class": "section-main-index",
  "blocks": [
    { "type": "@theme" },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Homepage",
      "blocks": [
        { "type": "hero" },
        { "type": "values-strip" },
        { "type": "featured-collections" },
        { "type": "farm-story" },
        { "type": "reviews-carousel" },
        { "type": "newsletter" },
        { "type": "instagram-strip" }
      ]
    }
  ]
}
{% endschema %}
