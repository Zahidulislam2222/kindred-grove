{%- comment -%}
  Static main section for templates/index.json. Hosts homepage Theme Blocks.
  Day 5 adds the full homepage (hero, values strip, featured collections,
  farm story, reviews, newsletter). Day 2 only establishes the block region.
{%- endcomment -%}

<section class="main-index container" style="padding-block: var(--section-spacing, var(--space-20));">
  {%- if section.blocks.size > 0 -%}
    <div class="stack stack-lg">
      {%- content_for 'blocks' -%}
    </div>
  {%- else -%}
    <p class="text-center text-muted">Add blocks to this homepage in the theme editor.</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Homepage",
  "class": "section-main-index",
  "blocks": [
    { "type": "@theme" },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Homepage",
      "blocks": [
        {
          "type": "text",
          "settings": {
            "element": "h1",
            "text_size": "5xl",
            "text_align": "center",
            "max_width": 24,
            "content": "<p>From the grove to your table.</p>"
          }
        },
        {
          "type": "text",
          "settings": {
            "element": "p",
            "text_size": "lg",
            "text_align": "center",
            "max_width": 52,
            "content": "<p>Single-origin pantry staples sourced direct from family farms across the Mediterranean and Levant. Honored traditions, traceable to the harvest.</p>"
          }
        },
        {
          "type": "button",
          "settings": {
            "label": "Shop the pantry",
            "variant": "primary",
            "size": "lg",
            "align": "center"
          }
        }
      ]
    }
  ]
}
{% endschema %}
