<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="{% if request.locale.iso_code == 'ar' %}rtl{% else %}ltr{% endif %}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_primary }}">

    {%- comment -%}
      Content Security Policy — baseline + observability hosts.
      Refined further in docs/SECURITY.md on Day 11/19 when Klaviyo, Judge.me lands.
      Sentry hosts whitelisted per ADR-005. web-vitals fetched from unpkg.
    {%- endcomment -%}
    <meta http-equiv="Content-Security-Policy" content="
      default-src 'self' *.shopify.com *.shopifycdn.com *.myshopify.com;
      script-src 'self' 'unsafe-inline' *.shopify.com *.shopifycdn.com js.sentry-cdn.com browser.sentry-cdn.com unpkg.com ajax.googleapis.com;
      style-src 'self' 'unsafe-inline' *.shopify.com *.shopifycdn.com;
      img-src 'self' data: blob: *.shopify.com *.shopifycdn.com;
      font-src 'self' data: *.shopifycdn.com;
      connect-src 'self' *.shopify.com *.shopifycdn.com *.sentry.io *.ingest.sentry.io ajax.googleapis.com a.klaviyo.com;
      frame-ancestors 'none';
    ">

    <title>
      {%- capture page_title_computed -%}
        {{- page_title -}}
        {%- if current_tags -%} &mdash; {{ current_tags | join: ', ' }}{%- endif -%}
        {%- unless page_title contains shop.name -%} &mdash; {{ shop.name }}{%- endunless -%}
      {%- endcapture -%}
      {{- page_title_computed | default: shop.name | escape -}}
    </title>

    {%- comment -%}
      Meta description: product template fills from product.description when
      the admin page description field is blank, so every PDP ships with a
      meaningful description without merchant work.
    {%- endcomment -%}
    {%- capture meta_desc -%}
      {%- if page_description != blank -%}
        {{ page_description }}
      {%- elsif template contains 'product' and product.description != blank -%}
        {{ product.description | strip_html | truncate: 160 }}
      {%- elsif template contains 'collection' and collection.description != blank -%}
        {{ collection.description | strip_html | truncate: 160 }}
      {%- endif -%}
    {%- endcapture -%}
    {%- if meta_desc != blank -%}
      <meta name="description" content="{{ meta_desc | escape }}">
    {%- endif -%}

    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="dns-prefetch" href="https://cdn.shopify.com">

    {%- comment -%}
      hreflang — emit one link per enabled locale + x-default. Uses
      canonical_url with Shopify's `localized_url` logic so each locale
      gets the proper `/ar/`, `/es/` prefix.
    {%- endcomment -%}
    {%- if shop.published_locales.size > 1 -%}
      {%- for locale in shop.published_locales -%}
        <link rel="alternate" hreflang="{{ locale.iso_code }}" href="{{ request.origin }}{{ request.path }}{% if locale.primary %}{% else %}?locale={{ locale.iso_code }}{% endif %}">
      {%- endfor -%}
      <link rel="alternate" hreflang="x-default" href="{{ canonical_url }}">
    {%- endif -%}

    {%- comment -%}
      Above-the-fold critical CSS inlined to prevent FOUC / CLS while the
      external stylesheets load. Includes the token system (cheap — ~2KB
      after gzip), html defaults, skip-link, site header skeleton, and
      hero minimums. Everything else is in the external stylesheet chain.
    {%- endcomment -%}
    <style>
      :root {
        --color-cream: #F8F4EC; --color-espresso: #1F1A14;
        --color-olive-500: #6B7F47; --color-olive-hover: #576839;
        --color-saffron-400: #D4A847;
        --color-surface: #FFFFFF; --color-border: #D1C9B8;
        --font-body: Inter, system-ui, -apple-system, Segoe UI, sans-serif;
        --font-heading: "Cormorant Garamond", Georgia, serif;
        --fs-base: 16px;
      }
      *,*::before,*::after { box-sizing: border-box; }
      html { color: var(--color-espresso); background: var(--color-cream); font-family: var(--font-body); font-size: var(--fs-base); line-height: 1.5; -webkit-font-smoothing: antialiased; }
      body { margin: 0; }
      img, svg, video, picture { max-width: 100%; height: auto; display: block; }
      .skip-link { position: absolute; top: 0; left: 0; padding: 12px 16px; background: var(--color-olive-hover); color: var(--color-cream); text-decoration: none; font-weight: 600; z-index: 500; transform: translateY(-100%); transition: transform 150ms ease-out; }
      .skip-link:focus { transform: translateY(0); }
      .kg-hero { min-height: 60vh; background-color: #1F1A14; }
      .site-header { padding: 16px 0; border-bottom: 1px solid var(--color-border); }
      .container { width: 100%; max-width: 1360px; margin-inline: auto; padding-inline: 16px; }
    </style>

    {%- comment -%}
      LCP hero hint: the hero block's own image renders with
      fetchpriority="high" + loading="eager" + width/height, which is
      what Core Web Vitals actually rewards. Explicit preload-link
      requires knowing the exact image URL at render time, which is
      not feasible from the layout without rendering the block —
      deferred to a per-section preload once `{% render_in_head %}`
      style primitives are available in Shopify Liquid.
    {%- endcomment -%}

    {%- comment -%} Open Graph — rich link previews on social {%- endcomment -%}
    <meta property="og:site_name" content="{{ shop.name | escape }}">
    <meta property="og:type" content="{% if template contains 'product' %}product{% elsif template contains 'article' %}article{% else %}website{% endif %}">
    <meta property="og:title" content="{{ page_title_computed | default: shop.name | escape }}">
    {%- if meta_desc != blank -%}
      <meta property="og:description" content="{{ meta_desc | escape }}">
    {%- endif -%}
    <meta property="og:url" content="{{ canonical_url }}">
    {%- if template contains 'product' and product.featured_image != blank -%}
      <meta property="og:image" content="https:{{ product.featured_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="{{ 1200 | times: product.featured_image.aspect_ratio | round }}">
      <meta property="product:price:amount" content="{{ product.price | money_without_currency | replace: ',', '' }}">
      <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
      <meta property="product:availability" content="{% if product.available %}in stock{% else %}out of stock{% endif %}">
    {%- elsif template contains 'collection' and collection.image != blank -%}
      <meta property="og:image" content="https:{{ collection.image | image_url: width: 1200 }}">
    {%- endif -%}

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ page_title_computed | default: shop.name | escape }}">
    {%- if meta_desc != blank -%}
      <meta name="twitter:description" content="{{ meta_desc | escape }}">
    {%- endif -%}
    {%- if template contains 'product' and product.featured_image != blank -%}
      <meta name="twitter:image" content="https:{{ product.featured_image | image_url: width: 1200 }}">
    {%- endif -%}

    {%- comment -%}
      Structured data — Organization on every page, BreadcrumbList on
      templates where a trail makes sense. Product + Article + FAQ +
      Recipe schemas live inside their respective templates/snippets.
    {%- endcomment -%}
    {% render 'schema-organization' %}
    {%- if template contains 'product' or template contains 'collection' or template contains 'page' or template contains 'article' -%}
      {% render 'schema-breadcrumb' %}
    {%- endif -%}

    {{ content_for_header }}

    {%- assign heading_font = settings.font_heading -%}
    {%- assign body_font    = settings.font_body -%}

    {%- if heading_font -%}{{ heading_font | font_face: font_display: 'swap' }}{%- endif -%}
    {%- if body_font -%}{{ body_font | font_face: font_display: 'swap' }}{%- endif -%}

    {{ 'theme.css'      | asset_url | stylesheet_tag }}
    {{ 'base.css'       | asset_url | stylesheet_tag }}
    {{ 'utilities.css'  | asset_url | stylesheet_tag }}
    {{ 'components.css' | asset_url | stylesheet_tag }}

    <style>
      :root {
        {%- if settings.color_primary != blank %}--color-primary: {{ settings.color_primary }};{% endif -%}
        {%- if settings.color_primary_hover != blank %}--color-primary-hover: {{ settings.color_primary_hover }};{% endif -%}
        {%- if settings.color_accent != blank %}--color-accent: {{ settings.color_accent }};{% endif -%}
        {%- if settings.color_secondary != blank %}--color-secondary: {{ settings.color_secondary }};{% endif -%}
        {%- if settings.color_background != blank %}--color-background: {{ settings.color_background }};{% endif -%}
        {%- if settings.color_surface != blank %}--color-surface: {{ settings.color_surface }};{% endif -%}
        {%- if settings.color_text != blank %}--color-text: {{ settings.color_text }};{% endif -%}
        {%- if settings.color_text_muted != blank %}--color-text-muted: {{ settings.color_text_muted }};{% endif -%}
        {%- if settings.color_border != blank %}--color-border: {{ settings.color_border }};{% endif -%}
        {%- if settings.page_width != blank %}--page-width: {{ settings.page_width }}px;{% endif -%}
        {%- if settings.section_spacing != blank %}--section-spacing: {{ settings.section_spacing }}px;{% endif -%}
        {%- if settings.font_size_base != blank %}--fs-base: {{ settings.font_size_base }}px;{% endif -%}
      }
    </style>

    {%- comment -%}
      Observability bootstrap — picks up merchant settings from the Observability group
      and hands them to assets/theme.js. Script is inline and tiny so it runs before
      the deferred theme bundle parses. `window.sentryOnLoad` is the Loader-Script hook
      (see ADR-005 + docs/CI-SECRETS.md).
    {%- endcomment -%}
    <script>
      window.__KG_OBS__ = {
        sentryDsn:   {{ settings.sentry_dsn | default: '' | json }},
        sentryEnv:   {{ settings.sentry_env | default: 'development' | json }},
        rumSample:   {{ settings.rum_sample_rate | default: 100 | json }},
        themeId:     {{ theme.id | json }},
        themeName:   {{ theme.name | json }},
        shopDomain:  {{ shop.permanent_domain | json }}
      };
      window.sentryOnLoad = function () {
        if (!window.Sentry || !window.__KG_OBS__.sentryDsn) return;
        window.Sentry.init({
          dsn: window.__KG_OBS__.sentryDsn,
          environment: window.__KG_OBS__.sentryEnv,
          release: 'kindred-grove@' + window.__KG_OBS__.themeId,
          sendDefaultPii: false,
          tracesSampleRate: 0,
          ignoreErrors: [
            'Non-Error promise rejection captured',
            'ResizeObserver loop limit exceeded',
            'ResizeObserver loop completed with undelivered notifications.'
          ],
          beforeSend: function (event) {
            if (event.user) {
              delete event.user.email;
              delete event.user.ip_address;
              delete event.user.username;
            }
            if (event.request && event.request.url) {
              event.request.url = event.request.url.split('?')[0];
            }
            return event;
          }
        });
      };
    </script>
    {%- if settings.sentry_dsn != blank -%}
      {%- assign sentry_key = settings.sentry_dsn | split: '@' | first | split: '//' | last -%}
      {%- if sentry_key != blank -%}
        {%- # theme-check-disable RemoteAsset -%}
        <script src="https://js.sentry-cdn.com/{{ sentry_key }}.min.js" crossorigin="anonymous" async></script>
        {%- # theme-check-enable RemoteAsset -%}
      {%- endif -%}
    {%- endif -%}

    {%- comment -%}
      Feature flags — loaded synchronously so blocks can read KG_FF during initial render.
      Definitions come from the Feature flags theme setting (JSON textarea); see ADR-008.
    {%- endcomment -%}
    <script>
      try {
        window.__KG_FF_DEFS__ = {{ settings.feature_flags_json | default: '[]' | json }};
      } catch (e) {
        window.__KG_FF_DEFS__ = [];
      }
    </script>
    <script src="{{ 'feature-flags.js' | asset_url }}" defer></script>
  </head>
  <body class="template-{{ template | replace: '.', '-' | handle }}">
    <a class="skip-link" href="#main">Skip to main content</a>

    {% section 'announcement' %}
    {% section 'header' %}

    <main id="main" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}
    {% section 'overlays' %}

    <script src="{{ 'announcement-bar.js' | asset_url }}" defer></script>
    <script src="{{ 'quick-view.js' | asset_url }}" defer></script>
    <script src="{{ 'cart-drawer.js' | asset_url }}" defer></script>
    <script src="{{ 'pantry-quiz.js' | asset_url }}" defer></script>
    <script src="{{ 'wholesale-form.js' | asset_url }}" defer></script>
    <script src="{{ 'predictive-search.js' | asset_url }}" defer></script>
    <script src="{{ 'newsletter.js' | asset_url }}" defer></script>
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </body>
</html>
