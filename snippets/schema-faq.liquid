{%- comment -%}
  FAQ Page JSON-LD. Called by blocks/product-faq.liquid when the block
  contains ≥1 question. Google's Rich Results only reward FAQ schema
  when all questions are visible on the page — don't inline FAQ schema
  for content that's hidden behind "load more" or non-expanded toggles.

  Accepts:
    items — array of { question, answer } objects
{%- endcomment -%}

{%- if items and items.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for item in items -%}
    {
      "@type": "Question",
      "name": {{ item.question | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ item.answer | strip_html | json }}
      }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}
