{%- comment -%}
  Language + currency switcher — uses Shopify's native locale_form and country_form.
  Renders nothing when only one option exists (most merchants start here).
  Accepts:
    show_language (bool, default true)
    show_currency (bool, default true)
    class (string) — extra wrapper classes
{%- endcomment -%}

{%- liquid
  assign show_lang = show_language | default: true
  assign show_curr = show_currency | default: true
  assign wrapper_class = 'locale-switcher'
  if class
    assign wrapper_class = wrapper_class | append: ' ' | append: class
  endif
-%}

<div class="{{ wrapper_class }}">
  {%- if show_lang and localization.available_languages.size > 1 -%}
    {%- form 'localization', class: 'locale-switcher__form', id: 'locale-switcher-lang' -%}
      <label for="LocaleSelect" class="visually-hidden">{{ 'header.language' | t }}</label>
      <span class="locale-switcher__icon" aria-hidden="true">{% render 'icon', name: 'globe', size: 16 %}</span>
      <select
        id="LocaleSelect"
        name="locale_code"
        class="locale-switcher__select"
        onchange="this.form.submit()"
      >
        {%- for lang in localization.available_languages -%}
          <option value="{{ lang.iso_code }}" lang="{{ lang.iso_code }}"{% if lang.iso_code == localization.language.iso_code %} selected{% endif %}>
            {{ lang.endonym_name | capitalize }}
          </option>
        {%- endfor -%}
      </select>
    {%- endform -%}
  {%- endif -%}

  {%- if show_curr and localization.available_countries.size > 1 -%}
    {%- form 'localization', class: 'locale-switcher__form', id: 'locale-switcher-curr' -%}
      <label for="CountrySelect" class="visually-hidden">{{ 'header.currency' | t }}</label>
      <select
        id="CountrySelect"
        name="country_code"
        class="locale-switcher__select"
        onchange="this.form.submit()"
      >
        {%- for country in localization.available_countries -%}
          <option value="{{ country.iso_code }}"{% if country.iso_code == localization.country.iso_code %} selected{% endif %}>
            {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
          </option>
        {%- endfor -%}
      </select>
    {%- endform -%}
  {%- endif -%}
</div>
