<section class="kg-account section">
  <div class="container kg-account__shell stack">
    <header class="stack-sm text-center">
      <p class="eyebrow">{{ 'customer.account.breadcrumb' | t }}</p>
      <h1 class="h1">{{ 'customer.reset_password.title' | t }}</h1>
      <p class="text-muted">{{ 'customer.reset_password.subtext' | t }}</p>
    </header>

    <div class="kg-account__panel">
      {%- form 'reset_customer_password', class: 'stack-sm' -%}
        {%- if form.errors -%}
          <ul class="kg-wholesale-form__errors" role="alert">
            {%- for field in form.errors -%}
              <li>{{ form.errors.messages[field] | escape }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
        {% render 'form-field', id: 'ResetPassword', type: 'password', name: 'customer[password]', label: 'customer.reset_password.password' | t, required: true, autocomplete: 'new-password' %}
        {% render 'form-field', id: 'ResetPasswordConfirm', type: 'password', name: 'customer[password_confirmation]', label: 'customer.reset_password.confirm' | t, required: true, autocomplete: 'new-password' %}
        <button type="submit" class="button button--primary">{{ 'customer.reset_password.submit' | t }}</button>
      {%- endform -%}
    </div>
  </div>
</section>
